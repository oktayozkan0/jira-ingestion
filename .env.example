# --- Database -------------------------------------------------------------
# The ingestion routine writes directly into the same Azure SQL database that
# Manager 360 reads from. Provide the connection either as a single SQLAlchemy
# style URL (copy/paste-compatible with the main app's DATABASE_URL) ...
DATABASE_URL=mssql+aioodbc://USERNAME:PASSWORD@YOUR-SERVER.database.windows.net:1433/YOUR-DB-NAME?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no&Connection+Timeout=30

# ... or as discrete fields (used only when DATABASE_URL is not set):
# DB_HOST=YOUR-SERVER.database.windows.net
# DB_PORT=1433
# DB_NAME=YOUR-DB-NAME
# DB_USER=USERNAME
# DB_PASSWORD=PASSWORD
# DB_DRIVER=ODBC Driver 18 for SQL Server

# --- Jira -----------------------------------------------------------------
# Credentials must never be committed. The scheduled-task machine supplies
# these through its own environment / .env file.
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=service-account@your-org.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_STORY_POINTS_FIELD=customfield_10038

# --- Backfill -------------------------------------------------------------
# Lower bound used when a tracked team has no tracking_start_date configured.
# DEFAULT_BACKFILL_START_DATE=2024-01-01

# --- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
# Directory for rotating run logs. Leave empty to log to the console only.
LOG_DIR=logs
